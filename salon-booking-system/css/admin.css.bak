.datetimepicker.sln-datetimepicker {
  padding: 4px;
  margin-top: 1px;
  white-space: normal;
  -webkit-border-radius: 4px;
  -moz-border-radius: 4px;
  border-radius: 4px;
  direction: ltr;
}

.datetimepicker.sln-datetimepicker table {
  border: none;
}

.datetimepicker.sln-datetimepicker.datetimepicker-rtl {
  direction: rtl;
}


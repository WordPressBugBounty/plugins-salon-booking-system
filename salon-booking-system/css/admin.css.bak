.sln-text--main {
  color: rgb(255, 255, 255);
}

.sln-text--contrast {
  color: rgb(0, 66, 88);
}

.sln-text--contrast--alpha {
  color: rgba(0, 66, 88, 0.3);
}

.sln-text--dark {
  color: rgb(0, 0, 0);
}

.sln-text--emphasis {
  color: #0277bd;
}

.sln-text--emphasis--hoverk {
  color: #0091ea;
}

.sln-text--grey {
  color: #888;
}

.sln-text--ok {
  color: #5bc24c;
}


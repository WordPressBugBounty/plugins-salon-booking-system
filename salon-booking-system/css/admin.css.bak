#sln-salon--admin .sln-admin-sidebar,
.sln-calendar--wrapper .sln-admin-sidebar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  align-items: center;
  padding: 0.8333333333rem;

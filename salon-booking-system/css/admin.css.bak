.sln-booking-reminder {
  position: relative;
  padding-left: 25px;
}

.sln-booking-reminder {
  position: relative;
  cursor: pointer;
  top: 0;
  transition: top ease 0.5s;
}

.sln-booking-reminder:hover {
  top: -3px;
}


  align-items: center;
  justify-content: center;
  padding: 0 1.6666666667rem;
  position: relative;
}
#sln-salon--admin .sln-inpage_navbar_wrapper .nav.nav-pills a span {
  -webkit-transition: border-bottom-color 250ms;

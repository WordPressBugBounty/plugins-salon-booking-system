/*@import 'settings-mixins';
//@import 'bootstrap';
@import 'admin_config';
#sln-salon--admin, .sln-calendar--wrapper  {
    @import 'typo';
    @import 'admin_components/inputs';
    @import 'admin_components/buttons';
    @import 'admin_components/boxes';

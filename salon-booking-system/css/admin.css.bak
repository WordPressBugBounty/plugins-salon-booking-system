    flex-wrap: nowrap;
  }
}
#sln-salon--admin .sln-checkbutton,
.sln-calendar--wrapper .sln-checkbutton {
  margin-right: 10px;
  margin-bottom: 10px;
  width: calc(50% - 10px);
  display: block;
  float: left;

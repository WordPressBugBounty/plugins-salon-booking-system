.sln-calendar--wrapper .sln-radiobox__wrapper--bd {
  position: relative;
}
#sln-salon--admin .sln-radiobox__wrapper--bd::after,
.sln-calendar--wrapper .sln-radiobox__wrapper--bd::after {
  display: block;

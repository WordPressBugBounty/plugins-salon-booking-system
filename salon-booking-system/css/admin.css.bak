}
#sln-salon--admin .sln-admin-sidebar.sln-admin-sidebar--free .sln-update-settings__wrapper,
.sln-calendar--wrapper .sln-admin-sidebar.sln-admin-sidebar--free .sln-update-settings__wrapper {

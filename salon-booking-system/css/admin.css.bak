#sln-salon--admin .cal-day-hour-part__rowactions,
.sln-calendar--wrapper .cal-day-hour-part__rowactions {
  width: 200px;
  height: 101px;
  position: absolute;
  top: 50%;
  left: 82px;
  transform: translate(0, -50%);
  display: grid;
  grid-template-columns: 90px 20px 90px;
  grid-template-rows: auto;
  align-items: center;
  pointer-events: none;
}

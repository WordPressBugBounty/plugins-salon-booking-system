:root {
  --accent--yelow: #ffdd50;
  --accent--blue: #013553;
  --accent--red: #ff5800;
  --accent--green: #3ad500;
  --accent--yellow: #ffdd50;
  --bg--red: #ffc2a2;
  --bg--green: #bbffa2;
  --bg--lightblue: #d0eeff;
  --text--blue--dark: #013553;
  --text--notice: #575757;
  --bgc--blue--dark: #013553;
  --cl--darkest: black;
  --cl--lightest: white;
}

.sln-iconuri--peoplestar::after {
